# ============================================================
#  API Keys & Credentials Template
#  Copy this file to `.env` and fill in your values.
#  NEVER commit `.env` to version control.
# ============================================================

# Google Earth Engine (service account or OAuth project)
GEE_PROJECT_ID=your-google-cloud-project-id
GEE_SERVICE_ACCOUNT=your-service-account@your-project-id.iam.gserviceaccount.com
GEE_KEY_FILE=secrets/your-key-file.json

# US Census / HUD (neighborhood boundary data, optional)
CENSUS_API_KEY=your-census-api-key

# General project paths (override defaults in src/config.py if needed)
DATA_DIR=data
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
